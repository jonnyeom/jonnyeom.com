{
    "name": "jonnyeom/jonnyeom.com",
    "license": "proprietary",
    "type": "project",
    "description": "Jonnyeom Personal Site",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "replace": {
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "require": {
        "php": "^8.5.5",
        "ext-intl": "*",
        "api-platform/core": "^3.4.17",
        "basvandorst/stravaphp": "^2.0.0",
        "doctrine/dbal": "^3.10.5",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7.0",
        "doctrine/orm": "^3.5.8",
        "league/commonmark": "^2.8.2",
        "nelmio/cors-bundle": "^2.6.1",
        "pentatrion/vite-bundle": "^8.2.4",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "rami/seo-bundle": "^1.2",
        "spatie/commonmark-highlighter": "^3.0.0",
        "spatie/yaml-front-matter": "^2.1.1",
        "symfony/apache-pack": "^1.0.1",
        "symfony/asset": "^7.4",
        "symfony/console": "^7.4",
        "symfony/dotenv": "^7.4",
        "symfony/expression-language": "^7.4",
        "symfony/flex": "^2.10.0",
        "symfony/form": "^7.4",
        "symfony/framework-bundle": "^7.4",
        "symfony/intl": "^7.4",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/process": "^7.4",
        "symfony/property-access": "^7.4",
        "symfony/property-info": "^7.4",
        "symfony/runtime": "^7.4",
        "symfony/security-bundle": "^7.4",
        "symfony/serializer": "^7.4",
        "symfony/stimulus-bundle": "^2.23.0",
        "symfony/translation": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/ux-live-component": "^3.0",
        "symfony/ux-react": "^2.28.2",
        "symfony/validator": "^7.4",
        "symfony/web-link": "^7.4",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "doctrine/coding-standard": "^14.0.0",
        "phpstan/phpdoc-parser": "^2.3.2",
        "phpstan/phpstan": "^2.1.52",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-doctrine": "^2.0.21",
        "phpstan/phpstan-symfony": "^2.0.15",
        "phpunit/phpunit": "^11.5.55",
        "rector/rector": "^2.0.19",
        "squizlabs/php_codesniffer": "^4.0.1",
        "symfony/browser-kit": "^7.4",
        "symfony/css-selector": "^7.4",
        "symfony/debug-bundle": "^7.4",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/phpunit-bridge": "^7.4",
        "symfony/stopwatch": "^7.4",
        "symfony/web-profiler-bundle": "^7.4"
    },
    "config": {
"optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "7.4.*",
            "docker": true
        }
    }
}
